# Tools
CC      = x86_64-w64-mingw32-gcc
LD      = x86_64-w64-mingw32-ld

# Paths
EFI_LIB_DIR = efi_lib

# Files
SRC = main.c
OBJ = build/main.o
SO  = build/main.so
EFI = build/BOOTX64.EFI


CFLAGS = -fshort-wchar\
        -mno-red-zone\
		-ffreestanding\
		-fno-stack-protector\
		-Wall\
		-Wextra\
		-I$(EFI_LIB_DIR)

LDFLAGS = \
	--nostdlib\
	--entry=uefi_main\
	--subsystem 10

all: $(EFI)

$(OBJ): $(SRC)
	@$(CC) $(CFLAGS) -c $< -o $@

$(EFI): $(OBJ)
	@$(LD) $(LDFLAGS) -o $@ $<
	@rm -f $(OBJ)

clean:
	@rm -rf $(OBJ) $(SO) $(EFI)

.PHONY: all clean